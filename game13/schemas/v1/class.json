{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://emberveil.rsg/schemas/v1/class.json",
  "title": "Emberveil Class (v1)",
  "type": "object",
  "required": ["id", "name", "primaryAttr"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,31}$" },
    "name": { "type": "string", "minLength": 1, "maxLength": 32 },
    "description": { "type": "string" },
    "primaryAttr": { "enum": ["str", "dex", "int", "wis"] },
    "startingStats": {
      "type": "object",
      "properties": {
        "str": { "type": "integer" },
        "dex": { "type": "integer" },
        "int": { "type": "integer" },
        "con": { "type": "integer" }
      }
    },
    "skillIds": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "defaultAppearanceId": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } }
  }
}
