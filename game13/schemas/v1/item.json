{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://emberveil.rsg/schemas/v1/item.json",
  "title": "Emberveil Item Base (v1)",
  "type": "object",
  "required": ["id", "name", "type"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,47}$" },
    "name": { "type": "string" },
    "type": { "enum": ["weapon", "armor", "accessory", "consumable"] },
    "subtype": { "type": "string" },
    "weaponCategory": { "enum": ["heavy", "light", "magic"] },
    "dmg": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
    "armor": { "type": "number" },
    "speed": { "type": "number" },
    "twoHanded": { "type": "boolean" },
    "statScaling": { "type": "string" },
    "slot": { "enum": ["main", "off", "head", "chest", "legs", "hands", "ring", "amulet"] },
    "iconId": { "type": "string" },
    "effects": { "type": "array", "items": { "$ref": "effect-dsl.json" } },
    "tags": { "type": "array", "items": { "type": "string" } }
  }
}
