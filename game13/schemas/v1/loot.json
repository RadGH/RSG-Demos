{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://emberveil.rsg/schemas/v1/loot.json",
  "title": "Emberveil Loot Specifier (v1)",
  "description": "Describes a loot drop. Either a deterministic list of items OR a weighted roll over type/base/quality/rarity ranges with an optional seed for reproducibility.",
  "type": "object",
  "oneOf": [
    {
      "title": "Deterministic",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["baseId"],
            "properties": {
              "baseId": { "type": "string" },
              "quality": { "enum": ["low","medium","high","elite","exotic"] },
              "rarity":  { "enum": ["normal","magic","rare","legendary"] },
              "affixes": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    {
      "title": "Rolled",
      "required": ["roll"],
      "properties": {
        "roll": {
          "type": "object",
          "required": ["types"],
          "additionalProperties": false,
          "properties": {
            "types":   { "type": "array", "items": { "enum": ["weapon","armor","accessory","consumable"] } },
            "bases":   { "type": "array", "items": { "type": "string" } },
            "quality": { "type": "object", "properties": { "min": { "type": "string" }, "max": { "type": "string" }, "weight": { "type": "string" } } },
            "rarity":  { "type": "object", "properties": { "min": { "type": "string" }, "max": { "type": "string" }, "weight": { "type": "string" } } },
            "count":   { "type": "integer", "minimum": 1, "default": 1 },
            "seed":    { "type": "integer", "description": "If set, drop is deterministic across runs." }
          }
        }
      }
    }
  ]
}
