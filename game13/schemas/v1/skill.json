{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://emberveil.rsg/schemas/v1/skill.json",
  "title": "Emberveil Skill (v1)",
  "description": "Authors a castable skill/spell. Effects are described via the Effect DSL; the runtime interprets them so no new JavaScript is required.",
  "type": "object",
  "required": ["id", "name", "class", "unlockLevel", "effects"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,47}$", "description": "Snake_case unique id." },
    "name": { "type": "string", "minLength": 1, "maxLength": 48 },
    "class": { "type": "string", "description": "class id this skill belongs to (warrior, mage, cleric, ...)" },
    "unlockLevel": { "type": "integer", "minimum": 1, "maximum": 30 },
    "description": { "type": "string", "maxLength": 280 },
    "mpCost": { "type": "integer", "minimum": 0, "default": 0 },
    "cooldown": { "type": "integer", "minimum": 0, "default": 0, "description": "Rounds between casts." },
    "targeting": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "side": { "enum": ["self", "ally", "allyOther", "party", "enemy", "enemies", "all"] },
        "count": { "type": "integer", "minimum": 1, "maximum": 8, "default": 1 },
        "aoe": { "enum": ["none", "adjacent2", "row", "column", "all"], "default": "none" }
      }
    },
    "effects": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "effect-dsl.json" }
    },
    "talents": {
      "type": "array",
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["id", "name", "effects"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "effects": { "type": "array", "items": { "$ref": "effect-dsl.json" } }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
