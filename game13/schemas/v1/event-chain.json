{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://emberveil.rsg/schemas/v1/event-chain.json",
  "title": "Emberveil Event Chain (v1)",
  "description": "A multi-step encounter/quest described as a series of nodes connected by flags (setFlag / requireFlag). The runtime selects the next node whose `requires` block is satisfied.",
  "type": "object",
  "required": ["id", "name", "nodes"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,47}$" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "actRange": { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "text", "choices"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "text": { "type": "string" },
          "requires": { "type": "array", "items": { "type": "object", "properties": { "flag": { "type": "string" }, "value": {} }, "required": ["flag"] } },
          "bgImage": { "type": "string" },
          "choices": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["label"],
              "additionalProperties": false,
              "properties": {
                "label": { "type": "string" },
                "requires": { "type": "array", "items": { "type": "object" } },
                "effects": { "type": "array", "items": { "$ref": "effect-dsl.json" } },
                "next": { "type": "string", "description": "id of the next node (or null to end chain)" }
              }
            }
          }
        }
      }
    }
  }
}
